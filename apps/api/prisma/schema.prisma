generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum TournamentStatus {
  ACTIVE
  ARCHIVED
}

enum TournamentParticipantRole {
  PLAYER
  MANAGER
}

enum MatchMode {
  ONE_VS_ONE
  TWO_VS_TWO
}

enum MatchStatus {
  PENDING_CONFIRMATION
  COMPLETED
  CANCELLED
}

enum TeamSide {
  A
  B
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  displayName  String
  passwordHash String?
  role         UserRole @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownedTournaments Tournament[]            @relation("TournamentOwner")
  memberships      TournamentParticipant[]
  createdMatches   Match[]                 @relation("CreatedMatches")
  confirmedMatches Match[]                 @relation("ConfirmedMatches")
  auditLogs        AuditLog[]              @relation("AuditActor")
  sessions         Session[]

  @@index([displayName])
}

model Session {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Tournament {
  id           String           @id @default(cuid())
  name         String
  slug         String           @unique
  passwordHash String
  ownerUserId  String
  status       TournamentStatus @default(ACTIVE)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  owner        User                    @relation("TournamentOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  participants TournamentParticipant[]
  matches      Match[]

  @@index([ownerUserId])
  @@index([status])
}

model TournamentParticipant {
  id           String                    @id @default(cuid())
  tournamentId String
  userId       String
  role         TournamentParticipantRole @default(PLAYER)
  joinedAt     DateTime                  @default(now())

  tournament Tournament         @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  matches    MatchParticipant[]

  @@unique([tournamentId, userId])
  @@index([userId])
  @@index([tournamentId])
}

model Match {
  id                String      @id @default(cuid())
  tournamentId      String
  mode              MatchMode
  status            MatchStatus @default(COMPLETED)
  playedAt          DateTime    @default(now())
  createdByUserId   String
  confirmedByUserId String?
  confirmedAt       DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  tournament  Tournament  @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  createdBy   User        @relation("CreatedMatches", fields: [createdByUserId], references: [id], onDelete: Restrict)
  confirmedBy User?       @relation("ConfirmedMatches", fields: [confirmedByUserId], references: [id], onDelete: SetNull)
  teams       MatchTeam[]

  @@index([tournamentId])
  @@index([playedAt])
  @@index([mode])
  @@index([status])
  @@index([confirmedByUserId])
}

model MatchTeam {
  id        String   @id @default(cuid())
  matchId   String
  side      TeamSide
  score     Int
  isWinner  Boolean
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  match        Match              @relation(fields: [matchId], references: [id], onDelete: Cascade)
  participants MatchParticipant[]

  @@unique([matchId, side])
  @@index([isWinner])
}

model MatchParticipant {
  id                      String   @id @default(cuid())
  matchTeamId             String
  tournamentParticipantId String
  createdAt               DateTime @default(now())

  matchTeam             MatchTeam             @relation(fields: [matchTeamId], references: [id], onDelete: Cascade)
  tournamentParticipant TournamentParticipant @relation(fields: [tournamentParticipantId], references: [id], onDelete: Restrict)

  @@unique([matchTeamId, tournamentParticipantId])
  @@index([tournamentParticipantId])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String
  entityType  String
  entityId    String
  before      Json?
  after       Json?
  createdAt   DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([createdAt])
}
